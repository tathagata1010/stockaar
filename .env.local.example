# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Razorpay plan IDs (create in Razorpay dashboard)
RAZORPAY_PLAN_MONTHLY=
RAZORPAY_PLAN_ANNUAL=

# Resend (email)
# IMPORTANT: Resend rejects gmail/yahoo/outlook senders. Verify a domain at
# https://resend.com/domains then set EMAIL_FROM=newsletter@yourdomain.com.
# If unset, Resend uses onboarding@resend.dev (deliverable but ugly).
# Display-name form is supported: EMAIL_FROM="Stockaar <onboarding@resend.dev>"
# EMAIL_REPLY_TO routes replies to a real inbox (gmail is fine here).
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=

# Cron auth (random secret, sent in Authorization header by Vercel Cron)
CRON_SECRET=

# NVIDIA NIM (free AI brief — get key at https://build.nvidia.com/)
NVIDIA_API_KEY=
# Optional model override (default: meta/llama-3.3-70b-instruct)
NVIDIA_MODEL=

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
